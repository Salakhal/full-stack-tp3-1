<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Gestion Utilisateurs</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          animation: {
            'fade-in': 'fadeIn 0.5s ease-in-out',
            'slide-up': 'slideUp 0.3s ease-out'
          },
          keyframes: {
            fadeIn: {
              '0%': { opacity: '0' },
              '100%': { opacity: '1' }
            },
            slideUp: {
              '0%': { transform: 'translateY(20px)', opacity: '0' },
              '100%': { transform: 'translateY(0)', opacity: '1' }
            }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-purple-50 min-h-screen">
  <!-- Navigation moderne -->
  <nav class="bg-white shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center space-x-3">
          <div class="bg-gradient-to-r from-blue-600 to-purple-600 p-2 rounded-lg">
            <i class="fas fa-users text-white text-xl"></i>
          </div>
          <div>
            <h1 class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
              Gestion Utilisateurs
            </h1>
            <p class="text-xs text-gray-500">CRUD Application</p>
          </div>
        </div>
        
        <div class="flex items-center space-x-4">
          <a href="/" class="text-gray-700 hover:text-blue-600 transition-colors duration-200">
            <i class="fas fa-home mr-1"></i> Accueil
          </a>
          <div class="h-6 w-px bg-gray-300"></div>
          <div class="text-sm text-gray-500">
            <i class="far fa-clock mr-1"></i> 
            <%= new Date().toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Messages de notification -->
  <% if (success) { %>
    <div class="fixed top-20 right-4 z-50 animate-slide-up">
      <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-lg shadow-lg max-w-md">
        <div class="flex items-center">
          <i class="fas fa-check-circle text-green-500 mr-3 text-xl"></i>
          <div>
            <p class="font-bold">Succès</p>
            <p><%= success %></p>
          </div>
          <button onclick="this.parentElement.parentElement.remove()" class="ml-auto text-green-700">
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>
    </div>
  <% } %>
  
  <% if (error) { %>
    <div class="fixed top-20 right-4 z-50 animate-slide-up">
      <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-lg max-w-md">
        <div class="flex items-center">
          <i class="fas fa-exclamation-circle text-red-500 mr-3 text-xl"></i>
          <div>
            <p class="font-bold">Erreur</p>
            <p><%= error %></p>
          </div>
          <button onclick="this.parentElement.parentElement.remove()" class="ml-auto text-red-700">
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>
    </div>
  <% } %>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in">